<h3><%= mode==='new' ? 'Nuevo alumno' : 'Editar alumno' %></h3>

<form method="post" action="<%= action %>" class="row g-3">
  <div class="col-12 col-md-6">
    <label class="form-label">Nombre completo</label>
    <input class="form-control" name="full_name" required value="<%= student.full_name || '' %>">
  </div>

  <div class="col-12 col-md-6">
    <label class="form-label">Teléfono (WhatsApp, E.164)</label>
   <input class="form-control" name="phone_e164" required placeholder="+521XXXXXXXXXX" value="<%= student.phone_e164 || '' %>">

<div class="form-check mt-2">
  <input class="form-check-input" type="checkbox" name="resend_credentials" id="resend_credentials" value="1">
  <label class="form-check-label" for="resend_credentials">
    Reenviar tarjeta de acceso por WhatsApp
  </label>
</div>

</div>

  <div class="col-12 col-md-3">
    <label class="form-label">Campus</label>
    <select class="form-select" name="campus_id" required>
      <% campuses.forEach(c => { %>
        <option value="<%= c.id %>" <%= String(student.campus_id)===String(c.id) ? 'selected':'' %>><%= c.name %></option>
      <% }) %>
    </select>
  </div>

  <div class="col-12 col-md-3">
    <label class="form-label">Turno</label>
    <select class="form-select" name="shift_id" required>
      <% shifts.forEach(s => { %>
        <option value="<%= s.id %>" <%= String(student.shift_id)===String(s.id) ? 'selected':'' %>><%= s.name %></option>
      <% }) %>
    </select>
  </div>

  <div class="col-12 col-md-3">
    <label class="form-label">Periodo</label>
    <select class="form-select" name="period_id" required>
      <% periods.forEach(p => { %>
        <option value="<%= p.id %>" <%= String(student.period_id)===String(p.id) ? 'selected':'' %>><%= p.name %></option>
      <% }) %>
    </select>
  </div>

  <div class="col-12 col-md-3">
    <label class="form-label">Año</label>
    <select class="form-select" name="year_id" required>
      <% years.forEach(y => { %>
        <option value="<%= y.id %>" <%= String(student.year_id)===String(y.id) ? 'selected':'' %>><%= y.year %></option>
      <% }) %>
    </select>
  </div>

  <div class="col-12 col-md-4">
    <label class="form-label">Carrera</label>
    <select class="form-select" name="career_id">
      <option value="">(Sin carrera)</option>
      <% careers.forEach(ca => { %>
        <option value="<%= ca.id %>" <%= String(student.career_id)===String(ca.id) ? 'selected':'' %>><%= ca.name %></option>
      <% }) %>
    </select>
    <div class="form-text">Edita carreras en Ajustes.</div>
  </div>

  <div class="col-6 col-md-2">
    <label class="form-label">Grado</label>
    <input class="form-control" name="grade" value="<%= student.grade || '' %>">
  </div>

  <div class="col-6 col-md-2">
    <label class="form-label">Grupo</label>
    <input class="form-control" name="group" value="<%= student.group || '' %>">
  </div>

  <div class="col-12 col-md-4">
    <label class="form-label">Paquete</label>
    <select class="form-select" name="package_id" required>
      <% packages.forEach(p => { %>
        <option value="<%= p.id %>" <%= String(student.package_id)===String(p.id) ? 'selected':'' %>><%= p.name %> - $<%= Number(p.cost).toFixed(2) %></option>
      <% }) %>
    </select>
  </div>

  <div class="col-12">
    <hr>
    <h5>Descuento (en pesos)</h5>
  </div>

  <div class="col-12 col-md-3">
    <label class="form-label">Monto descuento ($)</label>
    <input class="form-control" name="discount_amount" value="<%= student.discount_amount ?? 0 %>">
  </div>

  <div class="col-12 col-md-9">
    <label class="form-label">Motivo (opcional)</label>
    <input class="form-control" name="discount_reason" value="<%= student.discount_reason || '' %>">
  </div>

  <div class="col-12 d-flex gap-2">
<hr class="my-4">

<h5>Acceso automático al portal</h5>

<div class="row g-3">
  <div class="col-md-6">
    <label class="form-label">Usuario generado</label>
    <input
      type="text"
      id="portal_username_preview"
      class="form-control"
      readonly>
    <input
      type="hidden"
      name="portal_username"
      id="portal_username">
  </div>

  <div class="col-md-6">
    <label class="form-label">Contraseña generada</label>
    <input
      type="text"
      id="portal_password_preview"
      class="form-control"
      readonly
      value="itccteama">
    <input
      type="hidden"
      name="portal_password"
      id="portal_password"
      value="itccteama">
  </div>
</div>

<p class="text-muted mt-2">
  El usuario se genera automáticamente con el nombre y 2 letras del apellido.
  Si ya existe uno igual, el sistema agregará un número al final al guardar.
</p>
    <button class="btn btn-primary">Guardar</button>
    <a class="btn btn-outline-secondary" href="/students">Cancelar</a>
  </div>

  <% if (mode==='new') { %>
    <div class="col-12">
      <div class="alert alert-info">
        Al guardar, el sistema crea usuario del alumno y envía WhatsApp con credenciales (si está activo).
      </div>
    </div>
  <% } %>
</form>
<script>
  function generarUsuarioPortal() {
    const fullNameInput = document.querySelector('input[name="full_name"]');
    const usernamePreview = document.getElementById("portal_username_preview");
    const usernameHidden = document.getElementById("portal_username");
    const passwordPreview = document.getElementById("portal_password_preview");
    const passwordHidden = document.getElementById("portal_password");

    if (!fullNameInput || !usernamePreview || !usernameHidden) return;

    const fullName = (fullNameInput.value || "").trim().toLowerCase();
    const parts = fullName.split(/\s+/).filter(Boolean);

    const nombre = parts[0] || "";
    const apellido = parts[1] || "";

    let usernameBase = (nombre + apellido.substring(0, 2))
      .replace(/[^a-z0-9]/g, "");

    if (!usernameBase) {
      usernameBase = "alumno";
    }

    usernamePreview.value = usernameBase;
    usernameHidden.value = usernameBase;

    passwordPreview.value = "itccteama";
    passwordHidden.value = "itccteama";
  }

  document.addEventListener("DOMContentLoaded", () => {
    const fullNameInput = document.querySelector('input[name="full_name"]');
    if (fullNameInput) {
      fullNameInput.addEventListener("input", generarUsuarioPortal);
      generarUsuarioPortal();
    }
  });
</script>
