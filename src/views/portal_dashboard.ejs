<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Mi portal</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<nav class="navbar navbar-expand-lg navbar-dark bg-primary">
  <div class="container">
    <span class="navbar-brand">Portal del estudiante</span>
    <a href="/portal/logout" class="btn btn-sm btn-light">Cerrar sesión</a>
  </div>
</nav>

<div class="container py-4">
  <div class="mb-4">
    <h3><%= student.full_name %></h3>
    <p class="text-muted mb-1">Teléfono: <%= student.phone_e164 || "" %></p>
    <p class="text-muted mb-1">Paquete: <%= student.package_name || "" %></p>
    <p class="text-muted mb-1">Campus: <%= student.campus_name || "" %></p>
  </div>

  <div class="row mb-4">
    <div class="col-md-4 mb-3">
      <div class="card">
        <div class="card-body">
          <h6>Total del paquete</h6>
          <h4>$<%= Number(totals.total_due || 0).toFixed(2) %></h4>
        </div>
      </div>
    </div>

    <div class="col-md-4 mb-3">
      <div class="card">
        <div class="card-body">
          <h6>Total abonado</h6>
          <h4>$<%= Number(totals.total_paid || 0).toFixed(2) %></h4>
        </div>
      </div>
    </div>

    <div class="col-md-4 mb-3">
      <div class="card">
        <div class="card-body">
          <h6>Saldo pendiente</h6>
          <h4>$<%= Number(totals.balance || 0).toFixed(2) %></h4>
        </div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-body">
      <h5 class="mb-3">Mis pagos</h5>

      <% if (!payments || payments.length === 0) { %>
        <p class="text-muted">Aún no tienes pagos registrados.</p>
      <% } else { %>
        <div class="table-responsive">
          <table class="table table-striped">
            <thead>
              <tr>
                <th>Fecha</th>
                <th>Monto</th>
                <th>Método</th>
                <th>Estatus</th>
                <th>Nota</th>
              </tr>
            </thead>
            <tbody>
              <% payments.forEach(payment => { %>
                <tr>
                  <td><%= payment.created_at_fmt %></td>
                  <td>$<%= Number(payment.amount).toFixed(2) %></td>
                  <td><%= payment.method || "" %></td>
                  <td><%= payment.status || "" %></td>
                  <td><%= payment.note || "" %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</div>

</body>
</html>
