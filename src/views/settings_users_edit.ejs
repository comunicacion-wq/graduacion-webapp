<div class="d-flex justify-content-between align-items-center mb-3">
  <h3>Editar usuario</h3>
  <a href="/settings/users" class="btn btn-secondary btn-sm">Volver</a>
</div>

<div class="card">
  <div class="card-body">
    <form method="POST" action="/settings/users/<%= userEdit.id %>/edit">
      <div class="mb-3">
        <label class="form-label">Usuario</label>
        <input type="text" name="username" class="form-control" value="<%= userEdit.username %>" required>
      </div>

      <div class="mb-3">
        <label class="form-label">Nueva contraseña</label>
        <input type="text" name="password" class="form-control" placeholder="Déjalo vacío si no cambiarás contraseña">
      </div>

      <div class="mb-3">
        <label class="form-label">Rol</label>
        <select name="role" class="form-control" required>
          <option value="ADMIN" <%= userEdit.role === "ADMIN" ? "selected" : "" %>>ADMIN</option>
          <option value="CAJERO" <%= userEdit.role === "CAJERO" ? "selected" : "" %>>CAJERO</option>
          <option value="STUDENT" <%= userEdit.role === "STUDENT" ? "selected" : "" %>>STUDENT</option>
        </select>
      </div>

      <div class="mb-3">
        <label class="form-label">Estatus</label>
        <select name="active" class="form-control" required>
          <option value="true" <%= userEdit.active ? "selected" : "" %>>Activo</option>
          <option value="false" <%= !userEdit.active ? "selected" : "" %>>Inactivo</option>
        </select>
      </div>

      <button type="submit" class="btn btn-primary">Guardar cambios</button>
    </form>
  </div>
</div>
