<div class="d-flex justify-content-between align-items-center mb-3">
  <h3>Editar usuario</h3>
  <a href="/settings/users" class="btn btn-secondary btn-sm">Volver</a>
</div>

<div class="card">
  <div class="card-body">
    <form method="POST" action="/settings/users/<%= userEdit.id %>/edit">
      <div class="mb-3">
        <label class="form-label">Usuario</label>
        <input type="text" name="username" class="form-control" value="<%= userEdit.username %>" required>
      </div>

      <div class="mb-3">
        <label class="form-label">Nueva contraseña</label>
        <input type="text" name="password" class="form-control" placeholder="Déjalo vacío si no cambiarás contraseña">
      </div>

      <div class="mb-3">
        <label class="form-label">Rol</label>
        <select name="role" class="form-control" required>
          <option value="ADMIN" <%= userEdit.role === "ADMIN" ? "selected" : "" %>>ADMIN</option>
          <option value="CAJERO" <%= userEdit.role === "CAJERO" ? "selected" : "" %>>CAJERO</option>
          <option value="STUDENT" <%= userEdit.role === "STUDENT" ? "selected" : "" %>>STUDENT</option>
        </select>
      </div>

      <div class="mb-3">
        <label class="form-label">Estatus</label>
        <select name="active" class="form-control" required>
          <option value="true" <%= userEdit.active ? "selected" : "" %>>Activo</option>
          <option value="false" <%= !userEdit.active ? "selected" : "" %>>Inactivo</option>
        </select>
      </div>
<div class="mb-3">
  <label class="form-label">Campus autorizados</label>

  <div class="border rounded p-3">
    <% campuses.forEach(campus => { %>
      <div class="form-check">
        <input
          class="form-check-input"
          type="checkbox"
          name="campus_ids"
          value="<%= campus.id %>"
          id="campus_<%= campus.id %>"
          <%= assignedCampusIds.includes(campus.id) ? "checked" : "" %>
        >
        <label class="form-check-label" for="campus_<%= campus.id %>">
          <%= campus.name %>
        </label>
      </div>
    <% }) %>
  </div>

  <div class="form-text">
    Selecciona los campus que este usuario puede consultar y operar.
<div class="form-check">
      <input class="form-check-input" type="checkbox" name="create_students" id="create_students"
        <%= userEdit.permissions?.create_students ? "checked" : "" %>>
      <label class="form-check-label" for="create_students">Registrar alumnos</label>
    </div>

    <div class="form-check">
      <input class="form-check-input" type="checkbox" name="view_arrears" id="view_arrears"
        <%= userEdit.permissions?.view_arrears ? "checked" : "" %>>
      <label class="form-check-label" for="view_arrears">Ver adeudos</label>
    </div>

    <div class="form-check">
      <input class="form-check-input" type="checkbox" name="create_payments" id="create_payments"
        <%= userEdit.permissions?.create_payments ? "checked" : "" %>>
      <label class="form-check-label" for="create_payments">Registrar pagos</label>
    </div>

    <div class="form-check">
      <input class="form-check-input" type="checkbox" name="send_collection" id="send_collection"
        <%= userEdit.permissions?.send_collection ? "checked" : "" %>>
      <label class="form-check-label" for="send_collection">Enviar cobranza</label>
    </div>

    <div class="form-check">
      <input class="form-check-input" type="checkbox" name="cancel_payments" id="cancel_payments"
        <%= userEdit.permissions?.cancel_payments ? "checked" : "" %>>
      <label class="form-check-label" for="cancel_payments">Cancelar pagos</label>
    </div>

    <div class="form-check">
      <input class="form-check-input" type="checkbox" name="view_reports" id="view_reports"
        <%= userEdit.permissions?.view_reports ? "checked" : "" %>>
      <label class="form-check-label" for="view_reports">Ver reportes</label>
    </div>

    <div class="form-check">
      <input class="form-check-input" type="checkbox" name="manage_users" id="manage_users"
        <%= userEdit.permissions?.manage_users ? "checked" : "" %>>
      <label class="form-check-label" for="manage_users">Administrar usuarios</label>
    </div>

    <div class="form-check">
      <input class="form-check-input" type="checkbox" name="view_settings" id="view_settings"
        <%= userEdit.permissions?.view_settings ? "checked" : "" %>>
      <label class="form-check-label" for="view_settings">Ver ajustes</label>
    </div>

    <div class="form-check">
      <input class="form-check-input" type="checkbox" name="view_audit" id="view_audit"
        <%= userEdit.permissions?.view_audit ? "checked" : "" %>>
      <label class="form-check-label" for="view_audit">Ver auditoría</label>
    </div>
  </div>

  <div class="form-text">
    Marca únicamente las acciones que este usuario tiene autorizadas.
  </div>
</div>
  </div>
</div>
      <button type="submit" class="btn btn-primary">Guardar cambios</button>
    </form>
  </div>
</div>
