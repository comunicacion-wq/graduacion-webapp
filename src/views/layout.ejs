<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body{background:#f7f7fb;}
    .sidebar{min-height:100vh;}
    .nav-link.active{font-weight:600;}
    .badge-dot{width:10px;height:10px;border-radius:50%;display:inline-block;}
  </style>
</head>
<body>
<nav class="navbar navbar-expand-lg bg-white border-bottom">
  <div class="container-fluid">
    <a class="navbar-brand" href="/">Graduación</a>
    <div class="d-flex align-items-center gap-3">
      <a class="btn btn-outline-secondary btn-sm" href="/notifications">🔔 Notificaciones</a>
      <% if (user) { %>
        <span class="text-muted small">👤 <%= user.username %> (<%= user.role %>)</span>
        <a class="btn btn-outline-danger btn-sm" href="/logout">Salir</a>
      <% } %>
    </div>
  </div>
</nav>

<div class="container-fluid">
  <div class="row">
    <aside class="col-12 col-md-3 col-lg-2 bg-white border-end sidebar p-0">
      <div class="list-group list-group-flush">
        <a class="list-group-item list-group-item-action <%= active==='dashboard'?'active':'' %>" href="/">Dashboard</a>
        <a class="list-group-item list-group-item-action <%= active==='students'?'active':'' %>" href="/students">Control escolar</a>
        <a class="list-group-item list-group-item-action <%= active==='payments'?'active':'' %>" href="/finance/payments">Finanzas</a>
        <a class="list-group-item list-group-item-action <%= active==='arrears'?'active':'' %>" href="/arrears">Adeudos / Cobranza</a>
<a class="list-group-item list-group-item-action <%= active==='expenses' ? 'active' : '' %>" href="/expenses">Gastos</a>
<a class="list-group-item list-group-item-action <%= active==='expense_contacts'?'active':'' %>" href="/settings/expense-contacts">
  Proveedores
</a>

<% if (user && (user.role === "ADMIN" || user.permissions?.view_reports)) { %>
<a class="list-group-item list-group-item-action <%= active==='reports'?'active':'' %>" href="/reports">Reportes</a>
<% } %>

<a class="list-group-item list-group-item-action <%= active==='requests'?'active':'' %>" href="/requests">Solicitudes</a>

<% if (user && (user.role === "ADMIN" || user.permissions?.view_audit)) { %>
<a class="list-group-item list-group-item-action <%= active==='audit'?'active':'' %>" href="/audit">Auditoría</a>
<% } %>

<% if (user && (user.role === "ADMIN" || user.permissions?.view_settings)) { %>
<a class="list-group-item list-group-item-action <%= active==='settings'?'active':'' %>" href="/settings">Ajustes</a>
<% } %>
      </div>
    </aside>
    <main class="col-12 col-md-9 col-lg-10 p-4">
      <% if (flash && flash.length) { %>
        <% flash.forEach(f => { %>
          <div class="alert alert-<%= f.type %>"><%= f.msg %></div>
        <% }) %>
      <% } %>
      <%- body %>
    </main>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
