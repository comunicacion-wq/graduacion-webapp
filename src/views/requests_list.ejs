<div class="d-flex justify-content-between align-items-center mb-2">
  <h3 class="mb-0">Solicitudes</h3>
  <% if (user.role!=='ADMIN') { %>
    <a class="btn btn-primary" href="/requests/new">+ Nueva solicitud</a>
  <% } %>
</div>

<div class="table-responsive">
<table class="table table-sm table-striped align-middle">
  <thead>
    <tr><th>ID</th><th>Fecha</th><th>Campus</th><th>Alumno</th><th>Tipo</th><th>Estatus</th><th></th></tr>
  </thead>
  <tbody>
  <% requests.forEach(r => { %>
    <tr>
      <td>#<%= r.id %></td>
      <td><%= r.created_at_fmt %></td>
      <td><%= r.campus_name || '' %></td>
      <td><%= r.student_name || '' %></td>
      <td><%= r.request_type %></td>
      <td><span class="badge bg-<%= r.status==='PENDING'?'warning':(r.status==='APPROVED'?'success':'secondary') %>"><%= r.status %></span></td>
      <td class="text-end"><a class="btn btn-sm btn-outline-primary" href="/requests/<%= r.id %>">Ver</a></td>
    </tr>
  <% }) %>
  </tbody>
</table>
</div>
