<h3>Registrar abono</h3>

<form class="row g-2 mb-3" method="get" action="/finance/collect">
  <div class="col-12 col-md-8">
    <input class="form-control" name="q" placeholder="Buscar alumno (nombre o teléfono)" value="<%= q || '' %>">
  </div>
  <div class="col-12 col-md-4">
    <button class="btn btn-secondary w-100">Buscar</button>
  </div>
</form>

<% if (results && results.length) { %>
  <div class="list-group mb-3">
    <% results.forEach(r => { %>
      <a class="list-group-item list-group-item-action" href="/finance/collect?student_id=<%= r.id %>">
        <strong><%= r.full_name %></strong> — <span class="text-muted"><%= r.phone_e164 %></span>
        <div class="text-muted small"><%= r.campus_name || '' %> | <%= r.shift_name || '' %> | <%= r.period_name || '' %> / <%= r.grad_year || '' %></div>
      </a>
    <% }) %>
  </div>
<% } %>

<% if (student) { %>
  <div class="card">
    <div class="card-body">
      <h5 class="mb-1"><%= student.full_name %></h5>
      <div class="text-muted small"><%= student.campus_name %> | <%= student.shift_name %> | <%= student.period_name %> / <%= student.grad_year %></div>
      <hr>
      <div class="row g-2">
        <div class="col-12 col-md-3"><div class="text-muted small">Total a pagar</div><div class="fs-5">$<%= Number(totals.total_due).toFixed(2) %></div></div>
        <div class="col-12 col-md-3"><div class="text-muted small">Abonado</div><div class="fs-5">$<%= Number(totals.total_paid).toFixed(2) %></div></div>
        <div class="col-12 col-md-3"><div class="text-muted small">Saldo</div><div class="fs-5">$<%= Number(totals.balance).toFixed(2) %></div></div>
        <div class="col-12 col-md-3"><div class="text-muted small">Paquete</div><div class="fs-6"><%= student.package_name %></div></div>
      </div>
      <hr>
      <form method="post" action="/finance/collect">
        <input type="hidden" name="student_id" value="<%= student.id %>">
        <div class="row g-2">
          <div class="col-12 col-md-4">
            <label class="form-label">Monto a abonar</label>
            <input class="form-control" name="amount" required>
          </div>
          <div class="col-12 col-md-4">
            <label class="form-label">Método</label>
            <select class="form-select" name="method">
              <option>Efectivo</option>
              <option>Transferencia</option>
              <option>Tarjeta</option>
            </select>
          </div>
          <div class="col-12 col-md-4">
            <label class="form-label">Nota (opcional)</label>
            <input class="form-control" name="note">
          </div>
        </div>
        <div class="mt-3 d-flex gap-2">
          <button class="btn btn-primary">Guardar abono</button>
          <a class="btn btn-outline-secondary" href="/students/<%= student.id %>">Volver</a>
        </div>
      </form>
    </div>
  </div>
<% } %>
